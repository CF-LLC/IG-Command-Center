# Neon / Netlify Database (Postgres)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# OpenAI
OPENAI_API_KEY=your_openai_api_key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Demo mode defaults to true unless explicitly set to false.
NEXT_PUBLIC_DEMO_MODE=true

# Access protection (recommended for production)
# In production this defaults to enabled unless ACCESS_PROTECTION_ENABLED=false.
ACCESS_PROTECTION_ENABLED=true
ACCESS_ALLOWED_EMAIL=you@yourdomain.com
ACCESS_PASSWORD=change_this_to_a_long_random_password
ACCESS_SESSION_SECRET=change_this_to_a_long_random_secret
